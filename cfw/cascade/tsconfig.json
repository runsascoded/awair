{
  "compilerOptions": {
    "target": "es2022",
    "module": "es2022",
    "moduleResolution": "bundler",
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "esModuleInterop": true,
    "allowImportingTsExtensions": false,
    "skipLibCheck": true,
    "types": ["@cloudflare/workers-types"],
    "lib": ["es2022"],
    "allowJs": false,
    "resolveJsonModule": true
  },
  "include": ["src/**/*"]
}
